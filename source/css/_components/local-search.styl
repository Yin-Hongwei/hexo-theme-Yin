// Search dialog shell
.search-dialog
  position: fixed
  top: 5rem
  left: 50%
  z-index: 1001
  display: none
  margin-left: -15rem
  padding: 0
  width: 30rem
  border-radius: 12px
  background: $color-white
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12)
  overflow: hidden
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif

  hr
    margin: 0
    border: none
    border-top: 1px solid $wechat-divider

  span.search-close-button
    position: absolute
    top: 0.85rem
    right: 0.85rem
    color: $wechat-text-hint
    font-size: 1.1rem
    line-height: 1
    cursor: pointer
    transition: color 0.15s ease

    &:hover
      color: $wechat-text

  &__title
    padding: 1rem 1rem 0.75rem
    color: $wechat-text
    font-size: 17px
    font-weight: 500
    line-height: 1.3
    text-align: center

.search-mask
  position: fixed
  top: 0
  right: 0
  bottom: 0
  left: 0
  z-index: 1000
  display: none
  background: rgba(0, 0, 0, 0.45)

@media screen and (max-width: $sm)
  .search-dialog,
  .search-mask
    display: none !important

// Search input & results
#site-search
  #site-search-input-panel
    padding: 0 1rem 1rem

  .search-box
    position: relative
    margin: 0 auto
    max-width: 100%
    width: 100%

    &:before
      position: absolute
      top: 50%
      left: 0.65rem
      z-index: 1
      color: $wechat-text-hint
      font-family: FontAwesome
      font-size: 14px
      content: '\f002'
      transform: translateY(-50%)
      pointer-events: none

    input
      padding: 0.5rem 0.75rem 0.5rem 2rem
      width: 100%
      outline: none
      border: none
      border-radius: 6px
      background: $wechat-bg
      color: $wechat-text
      font-size: 15px
      line-height: 1.4
      box-sizing: border-box
      transition: background 0.15s ease

      &::placeholder
        color: $wechat-text-hint

      &:focus
        background: darken($wechat-bg, 2%)

  #site-search-results
    min-height: 7.5rem
    padding: 0 0 1.25rem
    border-top: 1px solid $wechat-divider

  .search__hint
    margin: 0
    padding: 2.25rem 1.5rem 0.75rem
    color: $wechat-text-hint
    text-align: center
    font-size: 14px
    line-height: 1.5

  #site-search-hits:not(:empty) + .search__hint
    display: none

  .search__hit-item
    position: relative
    border-bottom: 1px solid $wechat-divider
    transition: background 0.15s ease

    &:last-child
      border-bottom: none

    &:hover
      background: $wechat-bg

    a
      display: block
      padding: 0.65rem 1rem
      color: $wechat-text
      text-decoration: none
      font-size: 15px
      line-height: 1.4
      cursor: pointer

      &:hover
        color: $wechat-text

  .search__hits-empty
    padding: 1.5rem 1rem
    color: $wechat-text-muted
    text-align: center
    font-size: 14px

  .search-result-list
    overflow-y: auto
    max-height: 14rem

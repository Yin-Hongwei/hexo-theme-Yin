// Moments profile header (cover only)
$moments-cover-height = 280px

.moments-profile
  position: relative
  width: 100%
  margin-bottom: 1rem

  &.post-cover
    margin-bottom: 1rem

.moments-cover
  position: relative
  width: 100vw
  margin-left: calc(50% - 50vw)
  height: $moments-cover-height
  background-color: #8ea4b8
  background-image: linear-gradient(160deg, #7eb6d4 0%, #5a8fb5 45%, #4a7394 100%)
  background-position: center
  background-size: cover
  background-repeat: no-repeat
  cover-top-scrim()

  &[style*="background-image"]
    background-color: transparent

.moments-cover-content
  position: relative
  z-index: 2
  width: 100%
  height: 100%
  margin: 0
  padding: 0

#page-header.moments-profile-header
  position: fixed
  top: 0
  left: 0
  right: 0
  z-index: 101
  padding: 0 $header-padding-x
  min-height: $header-height
  width: 100%
  box-sizing: border-box
  font-size: $header-site-name-size
  border-bottom: 1px solid transparent
  transition: none
  isolation: isolate
  cover-header-bar()

  &::before
    content: ""
    position: absolute
    inset: 0
    z-index: -1
    background: $header-bar-bg-solid
    border-bottom: 1px solid $header-bar-border
    opacity: 0
    pointer-events: none

  &.scrolled::before
    opacity: 1

  .header-brand
    flex-shrink: 0
    min-width: 0
    display: flex
    align-items: center
    gap: 0.6rem

  .header-actions
    gap: $header-nav-gap

  #site-name
    font-weight: bold
    text-decoration: none
    cursor: pointer

  .toggle-menu
    display: none
    padding: 0
    line-height: 1
    cursor: pointer

  a
    text-decoration: none

  .site-page
    margin-left: 0

    &.social-icon
      font-size: $header-icon-size
      vertical-align: middle

      &.search
        font-size: $header-nav-size

        i
          font-size: $header-icon-size

  .search
    span
      display: none

    @media screen and (min-width: $sm)
      span
        display: inline

  .header-post-title
    position: absolute
    left: 50%
    top: 50%
    z-index: 1
    max-width: calc(100% - 22rem)
    padding: 0 0.5rem
    color: $color-black-light
    font-size: 0.85rem
    font-weight: 500
    line-height: 1.3
    text-align: center
    white-space: nowrap
    overflow: hidden
    text-overflow: ellipsis
    opacity: 0
    visibility: hidden
    pointer-events: none
    transform: translate(-50%, -50%)
    transition: none

  &.scrolled
    wechat-header-bar-text()

    .header-post-title
      opacity: 1
      visibility: visible
      color: $header-bar-text

    .header-logo
      background: $wechat-bg
      box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.06), 0 1px 4px rgba(0, 0, 0, 0.08)

@media screen and (min-width: ($bg + 1px))
  body.post-page:has(#sidebar.is-open) #page-header.moments-profile-header
    left: $sidebar-width
    right: 0
    width: auto
    transition: left 0.25s cubic-bezier(0.4, 0, 0.2, 1)

@media screen and (min-width: ($content-width + 32px))
  .moments-profile-header
    padding-left: calc((100vw - $content-width) / 2 + $header-padding-x)
    padding-right: calc((100vw - $content-width) / 2 + $header-padding-x)

  body.post-page:has(#sidebar.is-open) .moments-profile-header
    padding-left: 1rem
    padding-right: 1rem

@media screen and (max-width: $sm)
  $moments-cover-height = 220px

  .moments-cover
    height: $moments-cover-height

  #page-header.moments-profile-header
    padding: 0 $header-padding-x-mobile

    .header-post-title
      font-size: 0.8rem

    &.scrolled
      .header-post-title
        position: static
        flex: 1
        min-width: 0
        max-width: none
        transform: none
        padding: 0 0.35rem
        text-align: center


// Moments home feed
$moments-bg = $wechat-bg
$moments-link = $wechat-link
$moments-text = #191919
$moments-meta = $wechat-text-hint

#content-inner.moments-page
  padding-bottom: 0

.moments-feed
  padding: 0
  background: $moments-bg

.moments-item
  padding: 18px 16px 14px
  background: $color-white
  border-bottom: 1px solid $wechat-divider

  &:last-child
    border-bottom: none

.moments-body
  min-width: 0

.moments-title-row
  display: flex
  align-items: center
  flex-wrap: wrap
  gap: 8px
  margin-bottom: 4px

.moments-sticky
  display: inline-block
  padding: 0 6px
  border-radius: 3px
  background: rgba($color-orange, 0.12)
  color: $color-orange
  font-size: 11px
  line-height: 1.6

.moments-content
  color: $moments-text
  font-size: 15px
  line-height: 1.5
  word-break: break-word

  .content
    display: inline
    margin: 0
    word-break: break-word

    p
      display: inline
      margin: 0
      word-break: break-word

      &:has(img)
        display: block
        margin-top: 8px

    img
      max-width: 100%
      height: auto
      display: block
      margin: 8px 0
      border: none
      padding: 0

    .moments-img-grid
      display: grid
      gap: 4px
      width: 240px
      max-width: 100%
      margin-top: 8px

      &[data-count="2"],
      &[data-count="4"]
        grid-template-columns: repeat(2, 1fr)

      &[data-count="3"],
      &[data-count="5"],
      &[data-count="6"],
      &[data-count="7"],
      &[data-count="8"],
      &[data-count="9"]
        grid-template-columns: repeat(3, 1fr)

    .moments-img-cell
      position: relative
      aspect-ratio: 1
      overflow: hidden
      border-radius: 2px

      img
        width: 100%
        height: 100%
        margin: 0
        object-fit: cover

      a.fancybox
        display: block
        width: 100%
        height: 100%
        cursor: zoom-in

      &.is-hidden
        display: none

      &.has-more
        .moments-img-more
          position: absolute
          inset: 0
          display: flex
          align-items: center
          justify-content: center
          background: rgba(0, 0, 0, 0.45)
          color: $color-white
          font-size: 22px
          font-weight: 500
          pointer-events: none

    a.fancybox
      cursor: zoom-in

    h1, h2, h3, h4, h5, h6
      display: none

    .headerlink
      display: none

    a:not(.headerlink):not(.fancybox)
      color: $moments-link
      text-decoration: none
      border-bottom: 1px solid rgba($moments-link, 0.25)
      transition: color 0.15s ease, border-color 0.15s ease

      &:hover
        color: darken($moments-link, 8%)
        border-bottom-color: rgba($moments-link, 0.45)

    iframe
      display: block
      width: 100%
      max-width: 100%
      height: $iframe-height
      margin-top: 8px

  .moments-title
    color: $moments-text
    font-size: 15px
    font-weight: 600
    line-height: 1.5
    text-decoration: none

    &:hover
      color: $moments-link

.moments-more
  margin-left: 4px
  color: $moments-link
  font-size: 15px
  text-decoration: none

  &:hover
    opacity: 0.85

.moments-footer
  display: flex
  align-items: center
  justify-content: space-between
  margin-top: 10px

.moments-meta
  display: flex
  flex-wrap: wrap
  align-items: center
  gap: 4px
  color: $moments-meta
  font-size: 12px
  line-height: 1.4

  time
    color: $moments-meta

  &__sep
    color: $moments-meta

.moments-tag
  color: $moments-link
  text-decoration: none

  &:hover
    opacity: 0.85

.moments-actions
  position: relative
  flex-shrink: 0

  &:hover,
  &:focus-within
    .moments-action-menu
      opacity: 1
      visibility: visible
      transform: translateY(0)

  .moments-action-btn
    display: flex
    align-items: center
    justify-content: center
    gap: 4px
    width: 34px
    height: 20px
    padding: 0
    border: none
    border-radius: 3px
    background: #ededed
    cursor: pointer
    transition: background 0.15s ease

    &:hover
      background: #e0e0e0

  .moments-action-dot
    display: block
    width: 5px
    height: 5px
    border-radius: 50%
    background: $moments-link

  .moments-action-menu
    position: absolute
    right: 0
    bottom: calc(100% + 6px)
    z-index: 10
    display: flex
    overflow: hidden
    border-radius: 4px
    background: #4c4c4c
    opacity: 0
    visibility: hidden
    transform: translateY(4px)
    transition: all 0.15s ease
    white-space: nowrap

  .moments-action-item
    padding: 8px 14px
    color: $color-white
    font-size: 13px
    text-decoration: none

    &:hover
      background: rgba(255, 255, 255, 0.08)

    & + &
      border-left: 1px solid rgba(255, 255, 255, 0.12)

@media screen and (max-width: $sm)
  .moments-item
    padding: 14px 12px 10px

  .moments-content
    font-size: 14px

    .moments-title
      font-size: 14px

  .moments-actions.is-open .moments-action-menu
    opacity: 1
    visibility: visible
    transform: translateY(0)

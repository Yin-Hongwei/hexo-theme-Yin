// Site nav & page toolbar
#nav
  position: relative
  margin-bottom: 1rem

  &:not(.moments-profile)
    cover-top-scrim()

    > #page-header
      z-index: 2

    background-color: $theme-color
    background-attachment: fixed
    background-position: unquote($top_img_position)
    background-size: cover

    &.no-bg
      $bg-svg = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 304 304' width='304' height='304'%3E%3Cpath fill='%23dfe2e5' fill-opacity='0.4' d='M44.1 224a5 5 0 1 1 0 2H0v-2h44.1zm160 48a5 5 0 1 1 0 2H82v-2h122.1zm57.8-46a5 5 0 1 1 0-2H304v2h-42.1zm0 16a5 5 0 1 1 0-2H304v2h-42.1zm6.2-114a5 5 0 1 1 0 2h-86.2a5 5 0 1 1 0-2h86.2zm-256-48a5 5 0 1 1 0 2H0v-2h12.1zm185.8 34a5 5 0 1 1 0-2h86.2a5 5 0 1 1 0 2h-86.2zM258 12.1a5 5 0 1 1-2 0V0h2v12.1zm-64 208a5 5 0 1 1-2 0v-54.2a5 5 0 1 1 2 0v54.2zm48-198.2V80h62v2h-64V21.9a5 5 0 1 1 2 0zm16 16V64h46v2h-48V37.9a5 5 0 1 1 2 0zm-128 96V208h16v12.1a5 5 0 1 1-2 0V210h-16v-76.1a5 5 0 1 1 2 0zm-5.9-21.9a5 5 0 1 1 0 2H114v48H85.9a5 5 0 1 1 0-2H112v-48h12.1zm-6.2 130a5 5 0 1 1 0-2H176v-74.1a5 5 0 1 1 2 0V242h-60.1zm-16-64a5 5 0 1 1 0-2H114v48h10.1a5 5 0 1 1 0 2H112v-48h-10.1zM66 284.1a5 5 0 1 1-2 0V274H50v30h-2v-32h18v12.1zM236.1 176a5 5 0 1 1 0 2H226v94h48v32h-2v-30h-48v-98h12.1zm25.8-30a5 5 0 1 1 0-2H274v44.1a5 5 0 1 1-2 0V146h-10.1zm-64 96a5 5 0 1 1 0-2H208v-80h16v-14h-42.1a5 5 0 1 1 0-2H226v18h-16v80h-12.1zm86.2-210a5 5 0 1 1 0 2H272V0h2v32h10.1zM98 101.9V146H53.9a5 5 0 1 1 0-2H96v-42.1a5 5 0 1 1 2 0zM53.9 34a5 5 0 1 1 0-2H80V0h2v34H53.9zm60.1 3.9V66H82v64H69.9a5 5 0 1 1 0-2H80V64h32V37.9a5 5 0 1 1 2 0zM101.9 82a5 5 0 1 0 0-6 3 3 0 0 0 0 6zm16 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm32 48a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-16 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm32-16a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm0-32a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm16 32a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm32 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm0-16a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-16-64a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm16-16a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-32 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm0-16a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-16 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6z'%3E%3C/path%3E%3C/svg%3E"
      background-image: url($bg-svg) !important
      background-size: initial

    &.is-mobile
      background-attachment: local

#site-info
  display: flex
  flex-direction: column
  justify-content: center
  align-items: center
  padding: 0 1rem
  height: unit($top_img_height, "vh")

#site-title,
#site-sub-title
  color: $theme-header-text-color
  text-align: center
  text-shadow: $light-shadow
  line-height: 1.5

#site-title
  font-weight: bold
  font-size: 1.3rem

#site-sub-title
  font-size: 0.8rem

#site-social-icons
  margin: 0 auto
  width: 15rem
  text-align: center

  .social-icon
    margin: 0 0.5rem
    color: $theme-header-text-color
    text-shadow: $light-shadow
    font-size: 1.4rem
    cursor: pointer

    &:hover
      color: $color-white

#page-header
  position: absolute
  top: 0
  z-index: 99
  display: flex
  align-items: center
  justify-content: space-between
  gap: $header-nav-gap
  padding: 0 $header-padding-x
  min-height: $header-height
  width: 100%
  box-sizing: border-box
  border: none
  font-size: $header-site-name-size
  transition: transform 0.2s ease-in-out, opacity 0.2s ease-in-out, left 0.25s cubic-bezier(0.4, 0, 0.2, 1)

  .header-brand
    flex-shrink: 0
    min-width: 0

  .header-actions
    display: flex
    align-items: center
    justify-content: flex-end
    gap: $header-nav-gap
    flex-shrink: 0
    margin-left: auto

  .menus
    display: flex
    align-items: center
    gap: $header-nav-gap

  .toggle-menu
    display: none
    flex-shrink: 0
    padding: 0
    border: none
    background: transparent
    line-height: 1
    font-size: $header-icon-size
    color: $theme-header-text-color
    cursor: pointer
    transition: color 0.2s ease-in-out
    -webkit-tap-highlight-color: transparent
    touch-action: manipulation

    &:hover
      color: $color-white

  a
    color: $theme-header-text-color
    text-decoration: none

    &:hover
      color: $color-white

  .search
    span
      display: none

    @media screen and (min-width: $sm)
      span
        display: inline

  .dark-mode-toggle
    padding: 0.15rem 0
    border: none
    background: transparent
    color: inherit
    cursor: pointer
    line-height: 1

    &:hover
      color: $color-white

  .site-page
    position: relative
    display: inline-flex
    align-items: center
    gap: $header-icon-gap
    margin-left: 0
    padding: 0.15rem 0
    font-size: $header-nav-size
    line-height: 1.2
    white-space: nowrap
    cursor: pointer

    &.social-icon
      font-size: $header-icon-size
      vertical-align: middle

      &.search
        font-size: $header-nav-size

        i
          font-size: $header-icon-size

      &:not(.search)
        justify-content: center
        min-width: 1.25rem

      &::after
        display: none

    &::after
      position: absolute
      bottom: 0
      left: 0
      z-index: -1
      width: 0
      height: 2px
      background-color: $color-grey-light
      content: ""
      transition: all 0.3s ease-in-out

    &:hover
      &::after
        width: 100%

  &.fixed
    position: fixed
    top: -($header-height)
    z-index: 101
    wechat-header-bar(true)
    transition: transform 0.2s ease-in-out, opacity 0.2s ease-in-out, left 0.25s cubic-bezier(0.4, 0, 0.2, 1)

    .header-post-title
      color: $header-bar-text

  &.visible
    transform: translate3d(0, 100%, 0)

  #site-name
    display: inline-block
    line-height: 1.2
    font-weight: bold
    cursor: pointer

  .header-brand-avatar
    display: none
    flex-shrink: 0
    width: 36px
    height: 36px
    border: none
    border-radius: 50%
    overflow: hidden
    line-height: 0
    background: rgba(255, 255, 255, 0.15)
    box-shadow: 0 0 0 1.5px rgba(255, 255, 255, 0.9), 0 2px 10px rgba(0, 0, 0, 0.2)
    transition: box-shadow 0.2s ease-in-out, transform 0.15s ease

    img
      display: block
      width: 100%
      height: 100%
      object-fit: cover
      border: none
      border-radius: 0
      margin: 0
      padding: 0

    &:active
      transform: scale(0.94)

body > #page-header
  position: fixed
  top: 0
  z-index: 100
  cover-header-bar()

#nav > #page-header:not(.moments-profile-header)
  cover-header-bar()

#page-header.moments-profile-header
  .toggle-menu,
  a,
  #site-name,
  .dark-mode-toggle
    transition: none

@media screen and (min-width: ($bg + 1px))
  body.post-page:has(#sidebar.is-open) #page-header.fixed
    left: $sidebar-width
    right: 0
    width: auto

    .site-page
      display: none
      opacity: 0

  body.post-page:has(#sidebar.is-open) > #page-header
    left: $sidebar-width
    right: 0
    width: auto
    transition: left 0.25s cubic-bezier(0.4, 0, 0.2, 1)

@media screen and (min-width: $sm)
  #site-title
    font-size: 2rem

  #site-sub-title
    font-size: 1.2rem

  #page-header
    .mobile-nav-panel
      background: transparent
      box-shadow: none

    .mobile-nav-panel__header
      display: none

    .mobile-nav-panel__body
      display: flex
      align-items: center
      gap: $header-nav-gap

      a
        border-bottom: none

    .site-page.social-icon .menu-item-label
      display: none

@media screen and (max-width: $sm)
  #nav:not(.moments-profile)
    background-attachment: local

  #page-header:not(.moments-profile-header)
    padding: 0 $header-padding-x-mobile

  #page-header
    .header-brand
      display: flex
      align-items: center

    #site-name
      display: none

    .header-brand-avatar
      display: block
      background: rgba(255, 255, 255, 0.15)
      box-shadow: 0 0 0 1.5px rgba(255, 255, 255, 0.9), 0 2px 10px rgba(0, 0, 0, 0.2)

    &.moments-profile-header.scrolled .header-brand-avatar,
    &.fixed .header-brand-avatar
      background: $wechat-bg
      box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.06), 0 1px 4px rgba(0, 0, 0, 0.08)

@media screen and (min-width: ($sm + 1px))
  .mobile-nav-backdrop
    display: none

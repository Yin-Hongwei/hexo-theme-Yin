// Colors
$color-white = #FFFFFF
$color-grey-light = #EEEEEE
$color-grey = #dfe2e5
$color-grey-dark = #999
$color-black-light = #4C4948
$color-black = #242424
$color-black-dark = #000000
$color-blue = #82AAFF
$color-blue-dark = #6190e8
$color-orange = #F45D22
$color-border = #ddd

// Theme
$theme-color = $color-black
$theme-color-active = $color-black-dark
$theme-body-color = $color-white
$theme-header-color = $theme-color
$theme-header-text-color = $color-grey-light
$theme-header-text-color-active = $color-white

// Typography
$font-family = Lato, Helvetica Neue For Number, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, PingFang SC, Hiragino Sans GB, Microsoft YaHei, Helvetica Neue, Helvetica, Arial, sans-serif
$font-size = 14px
$code-font = consolas, Menlo, 'PingFang SC', 'Microsoft YaHei', monospace, Helvetica Neue For Number
$code-font-size = 13px
$code-block-padding-v = 0.375rem
$code-block-padding-h = 0.625rem

// Layout
$rem = 20px
$text-line-height = 2
$line-height-title = 1.1em
$content-width = 700px
$content-large-width = 900px
$iframe-height = (700 / 16 * 9)px
$img-border-padding = 4px
$img-border-color = $color-border
$light-shadow = 0.1rem 0.1rem 0.2rem rgba(0, 0, 0, 0.15)
$dark-shadow = 0.05rem 0.05rem 0.1rem rgba(0, 0, 0, 0.3)

// Post header image
$top_img_height = hexo-config("post.top_img_height") || 60
$top_img_position = hexo-config("post.top_img_position") || 'center'

// Code & blockquote
$code-foreground = $color-black-light
$code-background = rgba(27, 31, 35, 0.05)
$line-height-code-block = 1.5
$blockquote-color = #6a737d
$blockquote-padding-color = $color-grey

// Header
$header-height = 60px
$header-padding-x = 1.25rem
$header-padding-x-mobile = 1rem
$header-site-name-size = 18px
$header-nav-size = 16px
$header-icon-size = 16px
$header-nav-gap = 1.25rem
$header-icon-gap = 0.4rem

// WeChat design tokens
$wechat-green = #07c160
$wechat-green-light = #e8f8ef
$wechat-link = #576b95
$wechat-bg = #f7f7f7
$wechat-divider = #ededed
$wechat-text = #353535
$wechat-text-muted = #888
$wechat-text-hint = #b2b2b2

// WeChat dark mode tokens
$wechat-dark-bg = #111111
$wechat-dark-bg-secondary = #191919
$wechat-dark-bg-card = #1e1e1e
$wechat-dark-bg-elevated = #232323
$wechat-dark-divider = rgba(255, 255, 255, 0.08)
$wechat-dark-text = rgba(255, 255, 255, 0.8)
$wechat-dark-text-muted = rgba(255, 255, 255, 0.5)
$wechat-dark-text-hint = rgba(255, 255, 255, 0.3)
$wechat-dark-link = #7d90a9
$wechat-dark-green-light = rgba(7, 193, 96, 0.12)
$wechat-dark-fill-hover = rgba(255, 255, 255, 0.05)
$wechat-dark-action-bg = #3a3a3a
$wechat-dark-action-bg-hover = #444444
$wechat-dark-chevron = rgba(255, 255, 255, 0.25)
$wechat-dark-photo-bg = #2a2a2a
$wechat-dark-code-bg = $wechat-dark-bg-secondary

// WeChat-style header bar
$header-bar-bg = rgba($wechat-bg, 0.96)
$header-bar-bg-solid = $wechat-bg
$header-bar-text = $wechat-text
$header-bar-text-hover = $wechat-green
$header-bar-border = $wechat-divider
$header-bar-dark-bg = rgba($wechat-dark-bg-card, 0.92)
$header-bar-dark-bg-solid = $wechat-dark-bg-card

// Sidebar
$sidebar-width = 240px
$sidebar-bg = $wechat-bg
$sidebar-title-bg = $color-white
$sidebar-border = rgba(0, 0, 0, 0.06)
$sidebar-title-color = $wechat-text-muted
$sidebar-text-color = $wechat-text
$sidebar-text-muted = $wechat-text-hint
$sidebar-active-color = $wechat-green
$sidebar-active-bg = $wechat-green-light
$sidebar-hover-bg = rgba(0, 0, 0, 0.03)
$sidebar-toggle-width = 16px
$sidebar-toggle-height = 52px
$sidebar-toggle-radius = 8px
$sidebar-toggle-bg = $color-white
$sidebar-toggle-border = rgba(0, 0, 0, 0.08)
$sidebar-toggle-shadow = 0 2px 8px rgba(0, 0, 0, 0.08)
$sidebar-toggle-color = $wechat-text-muted
$sidebar-toggle-hover-bg = #fafafa
$go-up-bottom = 20px
$go-up-right = -16px

// Breakpoints
$sm = 768px
$bg = 1024px

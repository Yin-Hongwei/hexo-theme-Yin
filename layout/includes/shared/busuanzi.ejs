<div class="busuanzi">
  <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
  <% if (!is_post()) { %>
    <% if (theme.busuanzi.site_uv) { %>
      <span id="busuanzi_container_site_uv"><%- theme.busuanzi.site_uv_header %><span id="busuanzi_value_site_uv"></span><%- theme.busuanzi.site_uv_footer %></span>
    <% } %>
    <% if (theme.busuanzi.site_pv) { %>
      <% if (theme.busuanzi.site_uv) { %>
        <span class="footer-separator">|</span>
      <% } %>
      <span id="busuanzi_container_site_pv"><%- theme.busuanzi.site_pv_header %><span id="busuanzi_value_site_pv"></span><%- theme.busuanzi.site_pv_footer %></span>
    <% } %>
  <% } else { %>
    <% if (theme.busuanzi.page_pv) { %>
      <span id="busuanzi_container_page_pv"><%- theme.busuanzi.page_pv_header %><span id="busuanzi_value_page_pv"></span><%- theme.busuanzi.page_pv_footer %></span>
    <% } else { %>
      <% if (theme.busuanzi.site_uv) { %>
        <span id="busuanzi_container_site_uv"><%- theme.busuanzi.site_uv_header %><span id="busuanzi_value_site_uv"></span><%- theme.busuanzi.site_uv_footer %></span>
      <% } %>
      <% if (theme.busuanzi.site_pv) { %>
        <% if (theme.busuanzi.site_uv) { %>
          <span class="footer-separator">|</span>
        <% } %>
        <span id="busuanzi_container_site_pv"><%- theme.busuanzi.site_pv_header %><span id="busuanzi_value_site_pv"></span><%- theme.busuanzi.site_pv_footer %></span>
      <% } %>
    <% } %>
  <% } %>
</div>
